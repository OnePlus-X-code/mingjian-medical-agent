# ===== 基础配置 =====
# 数据目录路径（相对于 backend/ 目录）
DATA_DIR=../data

# 前端允许的跨域来源（逗号分隔）
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===== LLM 配置（Phase 5 使用，当前阶段不调用） =====
# 是否启用大模型调用（false 时使用规则兜底）
LLM_ENABLED=false

# OpenAI 兼容 API Key
LLM_API_KEY=

# OpenAI 兼容 API Base URL
LLM_BASE_URL=

# 模型名称
LLM_MODEL=

# LLM 请求超时（秒）
LLM_TIMEOUT_SECONDS=20
